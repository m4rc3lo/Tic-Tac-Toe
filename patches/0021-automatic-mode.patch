+        service.play(AudioCue.Victory);
+
+        Assert.Equal([AudioCue.Victory], inner.Cues);
+    }
+
+    private sealed class RecordingAudioService : IAudioService
+    {
+        public List<AudioCue> Cues { get; } = [];
+        public void play(AudioCue cue) => Cues.Add(cue);
+    }
+}
