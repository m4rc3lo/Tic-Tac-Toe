     $patterns = @(
-        'm4rc3lo',
-        'Dropbox\\univali',
-        'C:\\Users\\[^<>{}`"]+',
-        'AKIA[0-9A-Z]{16}',
-        'BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY',
