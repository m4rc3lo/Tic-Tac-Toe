+    /// <summary>
+    /// Confirma a rejeição de tabuleiro completo.
+    /// </summary>
+    [Fact]
+    public void choose_move_should_reject_full_board()
+    {
+        Board board = create_board(
+            (0, 0, Symbol.X),
+            (0, 1, Symbol.O),
+            (0, 2, Symbol.X),
+            (1, 0, Symbol.X),
+            (1, 1, Symbol.O),
+            (1, 2, Symbol.O),
+            (2, 0, Symbol.O),
+            (2, 1, Symbol.X),
+            (2, 2, Symbol.X));
