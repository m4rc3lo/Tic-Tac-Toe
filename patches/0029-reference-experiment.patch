+++ b/scripts/analyze-reference-experiment.py
@@ -0,0 +1,40 @@
+#!/usr/bin/env python3
+import csv, hashlib, json, pathlib, statistics, sys
+
+root = pathlib.Path(sys.argv[1] if len(sys.argv) > 1 else "artifacts/experiments/reference")
+manifest_path = root / "reference-manifest.json"
+manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
+required = ["experiment_id","run_number","x_strategy","o_strategy","seed","result","move_count","duration_ms","evaluated_states","failed","failure_message","application_version"]
+rows=[]
+for scenario in manifest["scenarios"]:
+    folder=root/scenario["directory"]
+    csv_path=folder/scenario["csvFile"]
+    json_path=folder/scenario["jsonFile"]
+    assert hashlib.sha256(csv_path.read_bytes()).hexdigest()==scenario["csvSha256"]
+    assert hashlib.sha256(json_path.read_bytes()).hexdigest()==scenario["jsonSha256"]
+    data=json.loads(json_path.read_text(encoding="utf-8"))
+    with csv_path.open(encoding="utf-8", newline="") as f:
+        reader=csv.DictReader(f, delimiter=";")
+        assert reader.fieldnames==required
+        scenario_rows=list(reader)
+    assert len(scenario_rows)==data["summary"]["totalRuns"]
+    for row in scenario_rows: row["scenario_id"]=scenario["scenarioId"]
+    rows.extend(scenario_rows)
+
+summary={"totalRuns":len(rows),"failedRuns":sum(r["failed"]=="true" for r in rows),"results":{}}
+for result in ("XWins","OWins","Draw","Failed"):
+    summary["results"][result]=sum(r["result"]==result for r in rows)
+summary["averageMoves"]=statistics.fmean(int(r["move_count"]) for r in rows if r["failed"]=="false")
+summary["averageDurationMs"]=statistics.fmean(int(r["duration_ms"]) for r in rows if r["failed"]=="false")
+(root/"reference-summary.json").write_text(json.dumps(summary,indent=2),encoding="utf-8")
+
+counts=summary["results"]
+width,height=700,360
+maxv=max(counts.values()) or 1
+bars=[]
+for i,(label,value) in enumerate(counts.items()):
+    x=90+i*145; h=220*value/maxv; y=290-h
+    bars.append(f'<rect x="{x}" y="{y:.1f}" width="80" height="{h:.1f}" fill="#0786b4"/><text x="{x+40}" y="315" text-anchor="middle">{label}</text><text x="{x+40}" y="{y-8:.1f}" text-anchor="middle">{value}</text>')
+svg=f'<svg xmlns="http://www.w3.org/2000/svg" width="{width}" height="{height}"><rect width="100%" height="100%" fill="white"/><text x="350" y="30" text-anchor="middle" font-size="20">Resultados do experimento de referência</text><line x1="60" y1="290" x2="660" y2="290" stroke="black"/>{"".join(bars)}</svg>'
+(root/"reference-results.svg").write_text(svg,encoding="utf-8")
+print(json.dumps(summary,indent=2))
